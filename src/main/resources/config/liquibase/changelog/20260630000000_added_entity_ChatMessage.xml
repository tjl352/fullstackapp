<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260630000000-1" author="jhipster">
        <createTable tableName="chat_message">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="role" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="${clobType}">
                <constraints nullable="false"/>
            </column>
            <column name="timestamp" type="${datetimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260630000000-2" author="jhipster">
        <addForeignKeyConstraint
            baseTableName="chat_message"
            baseColumnNames="user_id"
            constraintName="fk_chat_message_user_id"
            referencedTableName="jhi_user"
            referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>
