# Copy to application-local.yml and add your secrets.
# Get a Groq key at https://console.groq.com/keys
spring:
  ai:
    openai:
      api-key: gsk_your-groq-api-key-here
    model:
      chat: openai

# Optional — for dev-postgres-local if your Postgres app uses different credentials:
# POSTGRES_USER: your-user
# POSTGRES_PASSWORD: your-password
# POSTGRES_DB: fullstackapp
# POSTGRES_HOST: localhost
# POSTGRES_PORT: 5432
